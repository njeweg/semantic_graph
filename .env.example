# Anthropic API key for the graph agent (Stage 3)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model for the graph agent (default: claude-opus-4-5)
# Options: claude-opus-4-5, claude-sonnet-4-6, claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-opus-4-5

# Path to the repo (or monorepo) to index
REPO_ROOT=./repos/microservices-demo

# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
